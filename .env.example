# Copy this file to .env and fill in your key:
#   cp .env.example .env

# Google Gemini API key (free tier works fine).
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional: override the default model.
# Free-tier friendly default is gemini-3.1-flash-lite.
# GEMINI_MODEL=gemini-3.1-flash-lite

# ── LOCAL MODEL (no API key, no rate limits, no cost — great for testing) ──
# Run a local LLM via Ollama instead of Gemini. Works well on Apple Silicon (M-series).
#   1) brew install ollama && ollama serve
#   2) ollama pull llama3.2         (or qwen2.5:3b, phi3.5 — all run on 16GB RAM)
#   3) set these two lines:
# LLM_BACKEND=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_URL=http://localhost:11434

# Optional: Hugging Face token to silence the rate-limit warning when
# downloading the embedding/reranker models (not required).
# HF_TOKEN=your_hf_token

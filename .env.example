# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── LLM BACKEND SELECTION ──────────────────────────────────────────────────
# Which LLM to use for claim extraction, adjudication, synthesis, and chat.
#   gemini            → Google Gemini (default)
#   mistral           → Mistral API
#   grok              → xAI Grok
#   ollama            → local model, no key/limits/cost (needs `ollama serve`)
#   auto              → RECOMMENDED: rotate gemini → mistral → grok automatically,
#                       falling through on rate limits. Stacks all your free tiers
#                       so you rarely wait on any single provider's limit.
#   gemini,mistral    → an explicit fallback chain of your choosing
LLM_BACKEND=auto

# ── API KEYS (fill in the ones you have; `auto` uses whichever are present) ──
# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-3.1-flash-lite

# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_key_here
# MISTRAL_MODEL=mistral-small-latest

# xAI Grok — https://console.x.ai
XAI_API_KEY=your_grok_key_here
# GROK_MODEL=grok-2-latest

# ── LOCAL MODEL (Ollama) — no key, no rate limits, no cost ──────────────────
# Great for testing on Apple Silicon. Set LLM_BACKEND=ollama to use it.
#   brew install ollama && ollama serve
#   ollama pull qwen3:8b        (runs comfortably on 16GB RAM)
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_URL=http://localhost:11434

# ── Optional ────────────────────────────────────────────────────────────────
# HF token to silence the embedding/reranker download warning (not required).
# HF_TOKEN=your_hf_token
